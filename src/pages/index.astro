---
import BaseLayout from '../layouts/BaseLayout.astro';

const routes = [
  {
    href: '/for-bi-teams/',
    label: 'I run a BI team',
    text: 'Generated dbt models — staging, marts, tests, docs — raised as PRs against your repo. Your engineers review and merge. You own every line.',
  },
  {
    href: '/for-solo-analysts/',
    label: 'I am the data person',
    text: 'Upload your CSVs and spreadsheets. Get a queryable database with every transformation documented and inspectable. Working the same afternoon.',
  },
  {
    href: '/for-business-owners/',
    label: 'I own the business',
    text: 'Your spreadsheets and Xero, working together. Every number traceable to its source. Automatically checked before you see it.',
  },
  {
    href: '/for-consultancies/',
    label: 'I deliver analytics for clients',
    text: 'Standard dbt output in your house style. Generated models your consultants can explain and defend. No SNADLY branding.',
  },
];

const productScreens = [
  {
    src: '/product/autopilot.webp',
    alt: 'SNADLY Autopilot build screen showing warehouse build steps and progress.',
    title: 'Autopilot build',
    text: 'One run profiles source data, infers relationships, designs the schema, and builds the warehouse.',
    width: 1172,
    height: 886,
  },
  {
    src: '/product/relationships.webp',
    alt: 'SNADLY relationship inference screen showing source tables connected in a graph.',
    title: 'Relationship inference',
    text: 'Inspect detected keys, dimensions, and table relationships before the project is built.',
    width: 1172,
    height: 1540,
  },
];
---

<BaseLayout
  title="SNADLY | Your data. A real database. In minutes."
  description="Connect your systems and get a clean, queryable foundation your team can inspect, extend, or deliver. Working the same day."
>
  <section class="hero hero-home">
    <p class="eyebrow">SNADLY</p>
    <h1>Your data. A real database. In minutes, not weeks.</h1>
    <p class="lede">
      Connect your systems and get a clean, queryable foundation your team
      can inspect, extend, or deliver. Working the same day.
    </p>
  </section>

  <section class="section product-showcase" aria-labelledby="product-showcase-title">
    <div class="product-copy">
      <p class="eyebrow">Product</p>
      <h2 id="product-showcase-title">The warehouse build, visible from end to end.</h2>
      <p>
        SNADLY turns raw source data into an inspectable warehouse, then gives
        teams the dashboards, lineage, reports, and relationship evidence they
        need to trust the output.
      </p>
      <div class="actions">
        <a
          class="button"
          href="https://www.loom.com/share/4c05501e9fa14edd97f10663f32faa7d"
          target="_blank"
          rel="noopener noreferrer"
        >
          Watch video demo
        </a>
      </div>
    </div>

    <div class="product-stage">
      <figure class="product-shot product-shot-primary">
        <img
          src="/product/dashboard.webp"
          alt="SNADLY dashboard showing an event locations map, generated charts, and data tables."
          width="1220"
          height="1812"
          loading="eager"
          decoding="async"
        />
        <figcaption>
          <strong>Generated dashboard</strong>
          <span>Reports, maps, charts, and tables built from the new warehouse.</span>
        </figcaption>
      </figure>

      <div class="product-support-grid">
        {productScreens.map((screen) => (
          <figure class="product-shot">
            <img
              src={screen.src}
              alt={screen.alt}
              width={screen.width}
              height={screen.height}
              loading="lazy"
              decoding="async"
            />
            <figcaption>
              <strong>{screen.title}</strong>
              <span>{screen.text}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <section class="section split">
    <div>
      <p class="eyebrow">About Adrian White</p>
      <h2>Built by a data and AI practitioner.</h2>
    </div>
    <aside class="note bio-note">
      <div class="bio-profile">
        <img
          class="bio-photo"
          src="/people/adrian-white.webp"
          alt="Adrian White"
          width="320"
          height="320"
          loading="lazy"
          decoding="async"
        />
        <div>
          <h3>Adrian White</h3>
          <p>Auckland-based data, AI, and analytics practitioner.</p>
        </div>
      </div>
      <p>
        Adrian White is an Auckland-based data, AI, and analytics practitioner
        with a track record of pioneering applied AI solutions. He has
        contributed to AI safety through red teaming work with Anthropic, was a
        top entrant in the inaugural HackaPrompt competition, and was one of
        the leading Snowflake contributors on Stack Overflow during the
        platform's rapid growth era.
      </p>
      <p>
        Adrian demonstrated one of the world's earliest Snowflake AI
        integrations in Auckland in March 2023 and is the current world
        champion of PromptGolf. His work spans data platforms, AI evaluation,
        semantic search, accessibility technology, and rapid AI product
        development.
      </p>
      <div class="actions">
        <a
          class="button button-secondary"
          href="https://www.linkedin.com/in/seedatanz/"
          target="_blank"
          rel="noopener noreferrer"
        >
          LinkedIn profile
        </a>
      </div>
    </aside>
  </section>

  <section class="section">
    <div class="route-grid">
      {routes.map((route) => (
        <a class="route-card" href={route.href}>
          <h2>{route.label}</h2>
          <p>{route.text}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="section section-muted split">
    <div>
      <p class="eyebrow">What SNADLY produces</p>
      <h2>The useful part before the dashboard.</h2>
      <p>
        Standard, inspectable output — not a black box.
        Every transformation documented — see where every number came from.
        Portable — hand it to anyone, use it anywhere.
        Working in minutes, not weeks.
      </p>
    </div>
    <div class="feature-list">
      <article>
        <h3>Standard output</h3>
        <p>dbt SQL your team can inspect, modify, and keep using. No vendor lock-in.</p>
      </article>
      <article>
        <h3>Fast first value</h3>
        <p>Use your own data within hours instead of waiting through a long implementation cycle.</p>
      </article>
      <article>
        <h3>No black box</h3>
        <p>Every number is traceable to its source. The database is the product. The dashboard is optional.</p>
      </article>
    </div>
  </section>
</BaseLayout>
