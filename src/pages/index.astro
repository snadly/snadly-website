---
import BaseLayout from '../layouts/BaseLayout.astro';

const routes = [
  {
    href: '/for-bi-teams/',
    label: 'I run a BI team',
    text: 'Clear source-system modelling work from the backlog without lowering engineering or governance standards.',
  },
  {
    href: '/for-solo-analysts/',
    label: 'I am the data person',
    text: 'Stop rebuilding exports and work from a warehouse model you can query, inspect, and extend.',
  },
  {
    href: '/for-business-owners/',
    label: 'I own the business',
    text: 'See sales, cash, products, and customers together without learning data infrastructure first.',
  },
  {
    href: '/for-consultancies/',
    label: 'I deliver analytics for clients',
    text: 'Start warehouse projects faster while keeping the work reviewable, portable, and in your house style.',
  },
];
---

<BaseLayout
  title="Kilo | Your data warehouse in minutes"
  description="Connect source systems and generate a clean, queryable warehouse your team can use, extend, or hand over."
>
  <section class="hero hero-home">
    <p class="eyebrow">Kilo</p>
    <h1>Your data warehouse. In minutes, not weeks.</h1>
    <p class="lede">
      Connect your source systems and generate a clean, queryable warehouse your
      team can use, extend, or hand over.
    </p>
  </section>

  <section class="section">
    <div class="route-grid">
      {routes.map((route) => (
        <a class="route-card" href={route.href}>
          <h2>{route.label}</h2>
          <p>{route.text}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="section section-muted split">
    <div>
      <p class="eyebrow">What Kilo produces</p>
      <h2>The useful part before the dashboard.</h2>
      <p>
        Kilo turns connected source systems into structured warehouse models:
        staging, marts, tests, documentation, and lineage.
      </p>
    </div>
    <div class="feature-list">
      <article>
        <h3>Standard output</h3>
        <p>SQL and dbt-style project structure your team can inspect, modify, and keep using.</p>
      </article>
      <article>
        <h3>Fast first value</h3>
        <p>Use your own data early instead of waiting through a long implementation cycle.</p>
      </article>
      <article>
        <h3>No black box</h3>
        <p>The generated warehouse is the product. The dashboard is optional.</p>
      </article>
    </div>
  </section>
</BaseLayout>
