---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  robots?: string;
}

const {
  title = 'SNADLY',
  description = 'SNADLY turns messy business data into a clean, inspectable warehouse in minutes.',
  image = '/product/dashboard.webp',
  robots,
} = Astro.props;

const site = Astro.site ?? new URL('https://snadly.com');
const canonicalUrl = new URL(Astro.url.pathname, site).toString();
const imageUrl = new URL(image, site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    <meta name="theme-color" content="#f6f3ee" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:site_name" content="SNADLY" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      // Sticky header: add a .scrolled class once the page is scrolled past
      // a few pixels, so the header gains its frosted background + border.
      const header = document.querySelector('.site-header');
      if (header) {
        const onScroll = () => {
          header.classList.toggle('scrolled', window.scrollY > 8);
        };
        onScroll();
        window.addEventListener('scroll', onScroll, { passive: true });
      }

      // Scroll-reveal: fade + lift [data-reveal] elements into view as they
      // enter the viewport. Honors prefers-reduced-motion via CSS — when motion
      // is reduced, the [data-reveal] elements are visible regardless, so this
      // observer only adds the cosmetic .is-visible class.
      const revealTargets = document.querySelectorAll('[data-reveal]');
      if (revealTargets.length > 0 && 'IntersectionObserver' in window) {
        const revealObserver = new IntersectionObserver(
          (entries, observer) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            }
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.08 },
        );
        revealTargets.forEach((el) => revealObserver.observe(el));
      } else if (revealTargets.length > 0) {
        // No IntersectionObserver support — just show everything.
        revealTargets.forEach((el) => el.classList.add('is-visible'));
      }
    </script>
  </body>
</html>
